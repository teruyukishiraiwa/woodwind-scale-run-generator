/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: microphone=(), camera=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'

/*.html
  Content-Type: text/html; charset=utf-8

/assets/*.js
  Content-Type: application/javascript; charset=utf-8

/assets/*.css
  Content-Type: text/css; charset=utf-8

/assets/*.png
  Content-Type: image/png

/assets/*.jpg
  Content-Type: image/jpeg

/assets/*.mid
  Content-Type: audio/midi
